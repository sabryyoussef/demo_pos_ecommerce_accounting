<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_commercial_demo_dashboard" model="ir.actions.act_window">
        <field name="name">Demo Command Center</field>
        <field name="res_model">commercial.demo.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="commercial_demo_dashboard_main"/>
        <field name="target">current</field>
    </record>

    <!-- Replace former ir.actions.client (JS registry) with act_window + iframe form. -->
    <delete model="ir.actions.client" id="action_commercial_demo_build_story"/>

    <record id="action_commercial_demo_presentation" model="ir.actions.act_window">
        <field name="name">Client Presentation</field>
        <field name="res_model">commercial.demo.presentation</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="commercial_demo_presentation_main"/>
        <field name="target">current</field>
    </record>

    <record id="action_commercial_demo_build_story" model="ir.actions.act_window">
        <field name="name">Build Story Gallery</field>
        <field name="res_model">commercial.demo.build.story</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="commercial_demo_build_story_main"/>
        <field name="target">fullscreen</field>
    </record>

    <record id="action_commercial_demo_flashcards" model="ir.actions.act_window">
        <field name="name">Demo Flashcards</field>
        <field name="res_model">commercial.demo.flashcard</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="target">current</field>
    </record>

    <record id="action_commercial_demo_story" model="ir.actions.act_window">
        <field name="name">Demo Story</field>
        <field name="res_model">commercial.demo.story.step</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
    </record>

    <record id="action_commercial_demo_scenarios" model="ir.actions.act_window">
        <field name="name">Demo Scenarios</field>
        <field name="res_model">commercial.demo.scenario</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
    </record>

    <record id="action_crm_team_pos_dubai" model="ir.actions.act_window">
        <field name="name">POS — Dubai</field>
        <field name="res_model">crm.team</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="demo_crm_team_pos_dubai"/>
        <field name="target">current</field>
    </record>
    <record id="action_crm_team_pos_abu_dhabi" model="ir.actions.act_window">
        <field name="name">POS — Abu Dhabi</field>
        <field name="res_model">crm.team</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="demo_crm_team_pos_abu_dhabi"/>
        <field name="target">current</field>
    </record>
    <record id="action_crm_team_pos_northern" model="ir.actions.act_window">
        <field name="name">POS — Northern UAE</field>
        <field name="res_model">crm.team</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="demo_crm_team_pos_northern"/>
        <field name="target">current</field>
    </record>
</odoo>
